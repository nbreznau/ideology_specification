389.     local se = _se[`pm']
390.     local star = cond(abs((`b')/(`se')) > 2.58, "***", cond(abs((`b')/(`se')) > 1.96, "**", cond(abs((`b')
> /(`se')) > 1.64, "*", "")))
391.     local coeff : display %4.2f `b' "`star'"
392.     local stderr : display "(" %4.2f `se' ")"
393.     post `results' ("`model'") ("p56") ("`coeff'")
394.     post `results' ("") ("p56") ("`stderr'")
395. }
396. 
. * ------------------ GROUP3 MODELS ------------------
. *depends on DV which direction
. if "`dv'" == ""pos10s {"
397.         local gm "group1"
398. } 
399. else {
400.         local gm "group3"
401. }
402. foreach i in 01 02 03 10 11 12 13 {
403.     local model "g1g3_`i'_`dv'_peer"
404.     if "`i'" == "01" {
405.         reg `dv' `gm'  [aw=pscore/nmodel], cluster(teamid)
406.     }
407.     else if "`i'" == "02" {
408.         reg `dv' `gm'  stats_brw topic_brw [aw=pscore/nmodel], cluster(teamid)
409.     }
410.     else if "`i'" == "03" {
411.         reg `dv' `gm'  stats_brw topic_brw t2 t3 [aw=pscore/nmodel], cluster(teamid)
412.     }
413. 
.         else if "`i'" == "10" {
414.         reg `dv' `gm'  pbelief [aw=pscore/nmodel], cluster(teamid)
415.     }
416.     else if "`i'" == "11" {
417.         reg `dv' `gm'  stats_brw topic_brw pbelief [aw=pscore/nmodel], cluster(teamid)
418.     }
419.     else if "`i'" == "12" {
420.         reg `dv' `gm'  stats_brw topic_brw t2 t3 pbelief [aw=pscore/nmodel], cluster(teamid)
421.     }
422. 
.     local b = _b[`gm']
423.     local se = _se[`gm']
424.     local star = cond(abs((`b')/(`se')) > 2.58, "***", cond(abs((`b')/(`se')) > 1.96, "**", cond(abs((`b')
> /(`se')) > 1.64, "*", "")))
425.     local coeff : display %4.2f `b' "`star'"
426.     local stderr : display "(" %4.2f `se' ")"
427.     post `results' ("`model'") ("group3") ("`coeff'")
428.     post `results' ("") ("group3") ("`stderr'")
429. 
. }
430. 
. }
