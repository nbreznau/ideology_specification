. * ------------------ PROINDEX MODELS ------------------
. foreach dv in ame neg10s pos10s pos01 {
  2. foreach i in 01 02 03 10 11 12 {
  3.     local model "proindex_`i'_`dv'"
  4.     if "`i'" == "01" {
  5.         reg `dv' proindex  [aw=1/nmodel], cluster(teamid)
  6.     }
  7.     else if "`i'" == "02" {
  8.         reg `dv' proindex  stats_brw topic_brw [aw=1/nmodel], cluster(teamid)
  9.     }
 10.     else if "`i'" == "03" {
 11.         reg `dv' proindex  stats_brw topic_brw t2 t3 [aw=1/nmodel], cluster(teamid)
 12.     }
 13.         else if "`i'" == "10" {
 14.         reg `dv' proindex  pbelief [aw=1/nmodel], cluster(teamid)
 15.     }
 16.     else if "`i'" == "11" {
 17.         reg `dv' proindex  stats_brw topic_brw pbelief [aw=1/nmodel], cluster(teamid)
 18.     }
 19.     else if "`i'" == "12" {
 20.         reg `dv' proindex  stats_brw topic_brw t2 t3 pbelief [aw=1/nmodel], cluster(teamid)
 21.     }
 22. 
.     local b = _b[proindex]
 23.     local se = _se[proindex]
 24.     local star = cond(abs((`b')/(`se')) > 2.58, "***", cond(abs((`b')/(`se')) > 1.96, "**", cond(abs((`b')
> /(`se')) > 1.64, "*", "")))
 25.     local coeff : display %4.2f `b' "`star'"
 26.     local stderr : display "(" %4.2f `se' ")"
 27.         post `results' ("`model'") ("proindex") ("`coeff'")
 28.         post `results' ("") ("proindex") ("`stderr'")
 29. }
